{
  "name": "@boardwalk-labs/cli",
  "version": "0.1.15",
  "description": "The boardwalk CLI: author, validate, run, and deploy Boardwalk workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boardwalk-labs/cli.git"
  },
  "homepage": "https://github.com/boardwalk-labs/cli#readme",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.23.0",
  "bin": {
    "boardwalk": "bin/boardwalk.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "boardwalk": "tsx src/index.ts"
  },
  "dependencies": {
    "@boardwalk-labs/engine": "^0.1.11",
    "@boardwalk-labs/workflow": "^0.1.5",
    "commander": "^13.1.0",
    "env-paths": "^3.0.0",
    "esbuild": "^0.25.0",
    "open": "^10.1.0",
    "tar": "^7.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
